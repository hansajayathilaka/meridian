{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo nextest:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(just:*)",
      "Bash(pnpm:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat docs/tasks/*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "env": {
    "MERIDIAN_DOCS": "docs/",
    "RUST_BACKTRACE": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "awk '/^## .*NOW/{f=1} f{print} f&&/^---$/{exit}' docs/tasks/README.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_FILE_PATHS\" | grep -qE '\\.rs$'; then cargo fmt --all >/dev/null 2>&1 || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cargo clippy --workspace --quiet 2>&1 | tail -20 || true"
          }
        ]
      }
    ]
  }
}
